name: tangentcloud
services:
- name: backend
  github:
    repo: kamaraj/kyrochatbot
    branch: tcsaasbot
  source_dir: backend
  build_command: pip install -r requirements.txt
  http_port: 9100
  run_command: uvicorn app.main:app --host 0.0.0.0 --port 9100
  envs:
  - key: OPENAI_API_KEY
    scope: RUN_AND_BUILD_TIME
    value: ${OPENAI_API_KEY}
  - key: GOOGLE_API_KEY
    scope: RUN_AND_BUILD_TIME
    value: ${GOOGLE_API_KEY}
  - key: LLM_PROVIDER
    scope: RUN_AND_BUILD_TIME
    value: openai
  - key: DATABASE_URL
    scope: RUN_AND_BUILD_TIME
    value: ${DATABASE_URL}
  - key: REDIS_URL
    scope: RUN_AND_BUILD_TIME
    value: ${REDIS_URL}
  - key: QDRANT_PATH
    scope: RUN_AND_BUILD_TIME
    value: /app/qdrant_db
  health_check:
    http_path: /health
  log_destination_ref: tangentcloud_logs

- name: dashboard
  github:
    repo: kamaraj/kyrochatbot
    branch: tcsaasbot
  source_dir: dashboard
  build_command: npm ci && npm run build
  http_port: 3000
  run_command: npm run start
  envs:
  - key: NEXT_PUBLIC_API_URL
    scope: RUN_AND_BUILD_TIME
    value: https://${BACKEND_DOMAIN}/api
  - key: NODE_ENV
    scope: RUN_AND_BUILD_TIME
    value: production
  health_check:
    http_path: /
  log_destination_ref: tangentcloud_logs

- name: mobile
  github:
    repo: kamaraj/kyrochatbot
    branch: tcsaasbot
  source_dir: mobile
  build_command: npm ci
  http_port: 9102
  run_command: npm run start
  envs:
  - key: REACT_APP_API_URL
    scope: RUN_AND_BUILD_TIME
    value: https://${BACKEND_DOMAIN}/api
  - key: NODE_ENV
    scope: RUN_AND_BUILD_TIME
    value: production
  log_destination_ref: tangentcloud_logs

databases:
- name: postgres
  engine: PG
  version: "14"
  production: true
  
- name: redis
  engine: REDIS
  version: "7"
  production: true

static_sites:
- name: docs
  source_dir: docs
  routes:
  - path: /docs

ingress:
  rules:
  - match:
      domain: ${APP_DOMAIN}
      path:
        prefix: /api
    component:
      name: backend
  - match:
      domain: ${APP_DOMAIN}
      path:
        prefix: /
    component:
      name: dashboard

log_destinations:
- name: tangentcloud_logs
  datadog:
    token: ${DATADOG_API_TOKEN}
